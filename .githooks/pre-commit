#!/usr/bin/env bash
# Block committing an un-redacted ITRTG save file.
#
# The repo is public; raw saves embed the player's Steam id / account names /
# god name inside base64(gzip(base64(...))). This hook decodes every staged
# save (ManualSave*.txt, plus edited_*.txt from `save-edit`) and refuses the
# commit if its identity fields still hold real values (it reuses the redaction
# logic via `save-dump --check`, so no PII is hardcoded here). See
# reference/save_file_deserialization/FINDINGS.md.
#
# Enable once with:  git config core.hooksPath .githooks
set -euo pipefail

# `edited_*.txt` are normally gitignored, but a `git add -f` could stage one —
# content-check them too (defense in depth alongside the gitignore rule).
saves=$(git diff --cached --name-only --diff-filter=AM \
        | grep -E '(^|/)(ManualSave|edited_)[^/]*\.txt$' || true)
[ -z "$saves" ] && exit 0

echo "pre-commit: verifying staged save files are redacted…"
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
fail=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  git show ":$f" > "$tmp"          # check the *staged* content, not the worktree
  if cargo run -q -p save-parser --bin save-dump -- "$tmp" --check 2>/dev/null; then
    echo "  ok: $f"
  else
    echo "  BLOCKED: $f still contains identity fields."
    echo "           Redact it first:  cargo run -p save-parser --bin save-dump -- <save> --redact <out>"
    fail=1
  fi
done <<< "$saves"

if [ "$fail" -ne 0 ]; then
  echo "pre-commit: refusing to commit un-redacted save(s)."
fi
exit "$fail"
