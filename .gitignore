/target
/crates/gui/dist

# Per-user app state — auto-maintained by the tool, not source-controlled.
/data/app_state.yaml

# Derived artifacts of the save-deserialization work — regenerate with
# expand_save.ps1 or `save-dump --tree`.
/reference/save_file_deserialization/decompressed.bin
/reference/save_file_deserialization/save_layer1.txt
/reference/save_file_deserialization/save_expanded.txt

# Re-encoded saves from `save-dump --reencode` — these are unredacted real
# saves (they carry the player's Steam id / account names), produced only for
# the game-load test. Never commit them.
/reference/save_file_deserialization/reencode_test*.txt
**/reencode_*.txt

# Edited saves from `save-edit` — also unredacted real saves. Never commit them.
**/edited_*.txt

# Decompiled game C# from the Mono `Assembly-CSharp.dll`, produced by the
# save-model cross-check (e.g. `ilspycmd ... -o _cs_decomp`). This is
# copyrighted game source — reference only, NEVER commit. Only derived findings
# (key→field mappings written into FINDINGS.md / the Rust model) go in git.
/reference/save_file_deserialization/_cs_decomp/

# Kongregate / web-build "Save to file" exports (any name containing
# "SaveItRtG") carry identity and use a custom container our tooling decodes but
# can't redaction-check — never commit them. The broad glob catches names both
# with and without an underscore before the suffix (e.g. `2_CraftingBoostSaveItRtG.txt`).
**/*SaveItRtG*.txt
